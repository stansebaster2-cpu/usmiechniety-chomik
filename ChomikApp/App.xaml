<Application x:Class="ChomikApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources/>
                <ui:XamlControlsResources/>
            </ResourceDictionary.MergedDictionaries>
            <Color x:Key="ChomikOrange">#F4A026</Color>
            <Color x:Key="ChomikGreen">#7BC67E</Color>
            <Color x:Key="ChomikDark">#1E1E2E</Color>
            <SolidColorBrush x:Key="ChomikOrangeBrush" Color="{StaticResource ChomikOrange}"/>
            <SolidColorBrush x:Key="ChomikGreenBrush" Color="{StaticResource ChomikGreen}"/>
            <SolidColorBrush x:Key="ChomikDarkBrush" Color="{StaticResource ChomikDark}"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
