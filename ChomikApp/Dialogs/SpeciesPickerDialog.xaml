<Window x:Class="ChomikApp.Dialogs.SpeciesPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:loc="clr-namespace:ChomikApp.Localization"
        ui:WindowHelper.UseModernWindowStyle="True"
        Width="520" Height="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold"
                   Text="{Binding Source={x:Static loc:Strings.Current}, Path=SpeciesDialogTitle}"
                   Margin="0,0,0,8"/>
        <TextBlock Grid.Row="0" FontSize="13"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   Text="{Binding Source={x:Static loc:Strings.Current}, Path=SpeciesDialogBody}"
                   TextWrapping="Wrap" Margin="0,32,0,0"/>

        <ListBox Grid.Row="1" x:Name="SpeciesList" Margin="0,16,0,0"
                 SelectionChanged="SpeciesList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="8,6">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   FontSize="12" Margin="0,2,0,0">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} Ø{1} mm  |  Min: Ø{2} mm">
                                    <Binding Source="{x:Static loc:Strings.Current}" Path="SpeciesRecLabel"/>
                                    <Binding Path="RecommendedDiamMm"/>
                                    <Binding Path="MinWheelDiameterMm"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Margin="0,12,0,0"
                Background="#FFF3E0" CornerRadius="6" Padding="12,8"
                x:Name="HealthNotePanel" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="{Binding Source={x:Static loc:Strings.Current}, Path=SpeciesWarning}"
                           FontWeight="SemiBold" Foreground="#E65100" FontSize="13"/>
                <TextBlock x:Name="HealthNoteText" TextWrapping="Wrap"
                           Foreground="#BF360C" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnCustomize"
                    Content="{Binding Source={x:Static loc:Strings.Current}, Path=BtnCustomize}"
                    Click="BtnCustomize_Click"
                    Margin="0,0,8,0" Padding="16,8"/>
            <Button x:Name="BtnApply"
                    Content="{Binding Source={x:Static loc:Strings.Current}, Path=BtnApplyDefaults}"
                    Click="BtnApply_Click" Padding="16,8"
                    Background="#F4A026" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
