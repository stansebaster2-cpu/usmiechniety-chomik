<Window x:Class="ChomikApp.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:loc="clr-namespace:ChomikApp.Localization"
        ui:WindowHelper.UseModernWindowStyle="True"
        Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="800">
        <StackPanel Margin="32,28,32,28">

            <!-- Logo + tytuł -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="🐹" FontSize="36" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Source={x:Static loc:Strings.Current}, Path=AppTitle}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource ChomikOrangeBrush}"/>
                    <TextBlock Text="{Binding Source={x:Static loc:Strings.Current}, Path=AppSubtitle}"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
            </StackPanel>

            <Separator Margin="0,0,0,16"/>

            <!-- Autor -->
            <TextBlock Text="{Binding Source={x:Static loc:Strings.Current}, Path=AboutAuthorLabel}"
                       FontSize="11"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       Margin="0,0,0,2"/>
            <TextBlock Text="Sebastian Stańczykowski"
                       FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,16"/>

            <!-- Zdjęcie Zosi -->
            <Border CornerRadius="10" ClipToBounds="True"
                    MaxHeight="320" Margin="0,0,0,6"
                    MouseWheel="PhotoBorder_MouseWheel"
                    MouseLeftButtonDown="PhotoBorder_MouseLeftButtonDown"
                    MouseLeftButtonUp="PhotoBorder_MouseLeftButtonUp"
                    MouseMove="PhotoBorder_MouseMove"
                    Cursor="Hand">
                <Grid>
                    <!-- Placeholder gdy brak zdjęcia -->
                    <Border x:Name="PhotoPlaceholder"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🐹" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Source={x:Static loc:Strings.Current}, Path=AboutPhotoCaption}"
                                       FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                    </Border>
                    <!-- Właściwe zdjęcie -->
                    <Image x:Name="ZosiaPhoto"
                           Stretch="Uniform"
                           Visibility="Collapsed"
                           RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="PhotoScale"/>
                                <TranslateTransform x:Name="PhotoTranslate"/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                </Grid>
            </Border>
            <TextBlock x:Name="PhotoCaption"
                       Text="{Binding Source={x:Static loc:Strings.Current}, Path=AboutPhotoCaption}"
                       FontSize="12" HorizontalAlignment="Center"
                       FontStyle="Italic"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       Margin="0,0,0,16"
                       Visibility="Collapsed"/>

            <!-- Licencja -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="6" Padding="14,12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static loc:Strings.Current}, Path=AboutLicenseHeader}"
                               FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Source={x:Static loc:Strings.Current}, Path=AboutLicenseBody}"
                               TextWrapping="Wrap" FontSize="11" LineHeight="18"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
            </Border>

            <!-- GitHub -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔗 " FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Source={x:Static loc:Strings.Current}, Path=AboutGithubLabel}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="GithubLink"
                               FontSize="12" VerticalAlignment="Center"
                               Foreground="{StaticResource ChomikOrangeBrush}"
                               Cursor="Hand"
                               MouseLeftButtonUp="GithubLink_Click"
                               TextDecorations="Underline"
                               Text="{Binding Source={x:Static loc:Strings.Current}, Path=AboutGithubUrl}"/>
                </StackPanel>
            </Border>

            <!-- BLIK -->
            <Border Background="#E8F5E9" CornerRadius="6" Padding="14,12" Margin="0,0,0,12"
                    BorderBrush="#A5D6A7" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="💚 " FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Source={x:Static loc:Strings.Current}, Path=AboutBlikLabel}"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="#2E7D32"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="{Binding Source={x:Static loc:Strings.Current}, Path=AboutBlikNumber}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"
                                   Foreground="#1B5E20" VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <Button x:Name="BtnCopyBlik"
                                Content="{Binding Source={x:Static loc:Strings.Current}, Path=AboutBlikCopy}"
                                Click="BtnCopyBlik_Click"
                                Padding="10,4" FontSize="11"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Source={x:Static loc:Strings.Current}, Path=AboutBlikHint}"
                               FontSize="11" Foreground="#388E3C" FontStyle="Italic"/>
                </StackPanel>
            </Border>

            <!-- Claude -->
            <Border CornerRadius="6" Padding="14,10" Margin="0,0,0,16"
                    BorderBrush="#E0C87A" BorderThickness="1"
                    Background="#FFF8E1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="✨" FontSize="16"
                               VerticalAlignment="Top" Margin="0,1,10,0"/>
                    <TextBlock Text="{Binding Source={x:Static loc:Strings.Current}, Path=AboutClaude}"
                               TextWrapping="Wrap" FontSize="11" LineHeight="18"
                               Foreground="#5D4037"/>
                </DockPanel>
            </Border>

            <!-- Wersja -->
            <TextBlock Text="v1.0  ·  .NET 10  ·  Direct3D 11"
                       HorizontalAlignment="Center"
                       FontSize="10" FontFamily="Consolas"
                       Foreground="{DynamicResource SystemControlForegroundBaseLowBrush}"
                       Margin="0,0,0,16"/>

            <Button Content="{Binding Source={x:Static loc:Strings.Current}, Path=BtnClose}"
                    HorizontalAlignment="Center"
                    Padding="32,8"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </ScrollViewer>
</Window>
